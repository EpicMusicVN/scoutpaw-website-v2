# Content source — "json" (MVP) or "sanity" (future)
CONTENT_SOURCE=json

# Shopify mode — "mock" (MVP) or "live"
SHOPIFY_MODE=mock
SHOPIFY_STORE_DOMAIN=
SHOPIFY_STOREFRONT_TOKEN=

# Newsletter mode — "stub" (MVP, logs to console) or "live"
NEWSLETTER_MODE=stub
CONVERTKIT_API_KEY=
CONVERTKIT_FORM_ID=

# Public site URL (for OG images, metadataBase). Default fallback used if empty.
NEXT_PUBLIC_SITE_URL=

# Analytics — GA4 measurement ID (G-XXXXXXXXXX). Cookie banner gates load.
NEXT_PUBLIC_GA_ID=

# Revalidation secret (for Shopify webhook, post-MVP)
REVALIDATE_SECRET=

# Cloudflare R2 public base URL for asset CDN (e.g., https://images.scoutpaw.tv/).
# Leave empty in dev to fall back to local /public/assets/.
NEXT_PUBLIC_R2_BASE_URL=

# YouTube Data API v3 key (server-only — NEVER use NEXT_PUBLIC_ prefix).
# Empty value falls back to JSON content for channel + video metadata.
# Production: restrict by HTTP referrer in Google Cloud Console.
YOUTUBE_API_KEY=
